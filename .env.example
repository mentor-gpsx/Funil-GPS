# Portal Financeiro - Environment Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financial_portal
SQLITE_DB_PATH=./.data/cakto.db

# API
API_BASE_URL=http://localhost:3000

# Cakto Integration
CAKTO_API_URL=https://api.cakto.com.br
CAKTO_API_KEY=your_api_key_here

# Infinitepay Integration
INFINITEPAY_API_URL=https://api.infinitepay.com.br
INFINITEPAY_API_KEY=your_api_key_here

# Logging
LOG_LEVEL=info
LOG_FILE=./.logs/app.log

# Features
ENABLE_WEBHOOKS=true
ENABLE_AUTO_RECONCILIATION=true
RECONCILIATION_CHECK_INTERVAL=300000

# Development
DEBUG=false
MOCK_API=false
